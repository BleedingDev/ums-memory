{
  "name": "ums-memory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "node --import tsx apps/api/src/server.ts",
    "cli": "node --import tsx apps/cli/src/index.ts",
    "ums": "node --import tsx apps/ums/src/index.ts",
    "build:sfe:single": "node -e \"require('node:fs').mkdirSync('dist',{recursive:true})\" && bun build --compile --format esm --minify --sourcemap --bytecode apps/ums/src/index.ts --outfile dist/ums",
    "build:sfe:cli": "node -e \"require('node:fs').mkdirSync('dist',{recursive:true})\" && bun build --compile --format esm --minify --sourcemap --bytecode apps/cli/src/index.ts --outfile dist/ums-cli",
    "build:sfe:api": "node -e \"require('node:fs').mkdirSync('dist',{recursive:true})\" && bun build --compile --format esm --minify --sourcemap --bytecode apps/api/src/server.ts --outfile dist/ums-api",
    "build:sfe": "npm run build:sfe:single",
    "build:sfe:matrix": "node --import tsx scripts/build-sfe-matrix.ts",
    "build:sfe:linux-x64": "node --import tsx scripts/build-sfe-matrix.ts --targets bun-linux-x64",
    "build:sfe:windows-x64": "node --import tsx scripts/build-sfe-matrix.ts --targets bun-windows-x64",
    "build:sfe:matrix:split": "node --import tsx scripts/build-sfe-matrix.ts --apps cli,api",
    "build:sfe:cli:linux-x64": "node --import tsx scripts/build-sfe-matrix.ts --targets bun-linux-x64 --apps cli",
    "build:sfe:api:linux-x64": "node --import tsx scripts/build-sfe-matrix.ts --targets bun-linux-x64 --apps api",
    "build:sfe:cli:windows-x64": "node --import tsx scripts/build-sfe-matrix.ts --targets bun-windows-x64 --apps cli",
    "build:sfe:api:windows-x64": "node --import tsx scripts/build-sfe-matrix.ts --targets bun-windows-x64 --apps api",
    "test:api": "tsx --test apps/api/test/*.test.ts apps/cli/test/*.test.ts",
    "test:sfe": "tsx --test apps/cli/test/cli.sfe.test.ts apps/api/test/server.sfe.test.ts apps/cli/test/single.sfe.test.ts",
    "test:ums": "UMS_IMPL_MODULE=./apps/api/src/ums/engine.ts UMS_IMPL_EXPORT=createUmsEngine tsx --test tests/unit/*.test.ts tests/integration/*.test.ts",
    "test": "npm run test:api && npm run test:ums",
    "lint:ts": "oxlint --deny-warnings --tsconfig tsconfig.json --ignore-pattern \"apps/**/test/**/*.ts\" --ignore-pattern \"apps/**/bench/**/*.ts\" --ignore-pattern \"**/adapter-registry.test.ts\" apps libs",
    "lint:config-json": "node --import tsx scripts/validate-strict-json.ts tsconfig*.json apps/*/tsconfig.json libs/shared/tsconfig.json",
    "validate:tsconfig-policy": "node --import tsx scripts/validate-tsconfig-policy-lock.ts",
    "validate:effect-beta-pin": "node --import tsx scripts/validate-effect-beta-pin.ts",
    "validate:runtime-ts-suppressions": "node --import tsx scripts/validate-runtime-ts-suppressions.ts",
    "validate:legacy-shims": "node --import tsx scripts/validate-legacy-runtime-shims.ts",
    "validate:cutover": "node --import tsx scripts/validate-legacy-runtime-cutover.ts",
    "validate:vector-eval": "node --import tsx scripts/validate-vector-retrieval-evaluation.ts",
    "validate:federation-model": "node --import tsx scripts/validate-cross-repo-federation-model.ts",
    "format:check:ts": "oxfmt --check \"{apps,libs}/**/*.ts\" \"tsconfig*.json\" \"apps/*/tsconfig.json\" \"libs/shared/tsconfig.json\"",
    "format:write:ts": "oxfmt \"{apps,libs}/**/*.ts\" \"tsconfig*.json\" \"apps/*/tsconfig.json\" \"libs/shared/tsconfig.json\"",
    "ultracite:check": "ultracite check",
    "ultracite:fix": "ultracite fix",
    "quality:ts": "npm run lint:ts && npm run lint:config-json && npm run validate:tsconfig-policy && npm run validate:effect-beta-pin && npm run validate:runtime-ts-suppressions && npm run validate:legacy-shims && npm run validate:cutover && npm run validate:vector-eval && npm run validate:federation-model && npm run format:check:ts && npm run typecheck",
    "ci:verify": "npm run quality:ts && npm run test && npm run test:sfe && npm run build:sfe:single",
    "typecheck": "tsc -b --pretty false",
    "bench:api": "node --import tsx apps/api/bench/benchmark.ts",
    "bench:ums": "UMS_IMPL_MODULE=./apps/api/src/ums/engine.ts UMS_IMPL_EXPORT=createUmsEngine node --import tsx benchmarks/ums-latency-benchmark.ts",
    "bench": "npm run bench:api && npm run bench:ums",
    "validate:ingestion": "node --import tsx scripts/validate-ingestion.ts",
    "ingest:coding-history": "node --import tsx scripts/ingest-coding-history.ts",
    "pilot:report": "node --import tsx scripts/generate-pilot-rollout-report.ts",
    "pilot:dashboard": "node --import tsx scripts/generate-pilot-kpi-dashboard.ts",
    "pilot:tune": "node --import tsx scripts/generate-ranking-decay-tuning.ts",
    "pilot:slo": "node --import tsx scripts/evaluate-production-slos.ts"
  },
  "dependencies": {
    "effect": "4.0.0-beta.25",
    "tsx": "^4.20.5"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "5.8.2",
    "ultracite": "^7.2.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
