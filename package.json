{
  "name": "ums-memory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "bun apps/api/src/server.ts",
    "cli": "bun apps/cli/src/index.ts",
    "ums": "bun apps/ums/src/index.ts",
    "build:sfe:single": "bun -e \"import { mkdirSync } from 'node:fs'; mkdirSync('dist',{recursive:true});\" && bun build --compile --format esm --minify --sourcemap --bytecode apps/ums/src/index.ts --outfile dist/ums",
    "build:sfe:cli": "bun -e \"import { mkdirSync } from 'node:fs'; mkdirSync('dist',{recursive:true});\" && bun build --compile --format esm --minify --sourcemap --bytecode apps/cli/src/index.ts --outfile dist/ums-cli",
    "build:sfe:api": "bun -e \"import { mkdirSync } from 'node:fs'; mkdirSync('dist',{recursive:true});\" && bun build --compile --format esm --minify --sourcemap --bytecode apps/api/src/server.ts --outfile dist/ums-api",
    "build:sfe": "bun run build:sfe:single",
    "build:sfe:matrix": "bun scripts/build-sfe-matrix.ts",
    "build:sfe:linux-x64": "bun scripts/build-sfe-matrix.ts --targets bun-linux-x64",
    "build:sfe:windows-x64": "bun scripts/build-sfe-matrix.ts --targets bun-windows-x64",
    "build:sfe:matrix:split": "bun scripts/build-sfe-matrix.ts --apps cli,api",
    "build:sfe:cli:linux-x64": "bun scripts/build-sfe-matrix.ts --targets bun-linux-x64 --apps cli",
    "build:sfe:api:linux-x64": "bun scripts/build-sfe-matrix.ts --targets bun-linux-x64 --apps api",
    "build:sfe:cli:windows-x64": "bun scripts/build-sfe-matrix.ts --targets bun-windows-x64 --apps cli",
    "build:sfe:api:windows-x64": "bun scripts/build-sfe-matrix.ts --targets bun-windows-x64 --apps api",
    "test:api": "bun test apps/api/test/*.test.ts apps/cli/test/*.test.ts",
    "test:sfe": "bun test apps/cli/test/cli.sfe.test.ts apps/api/test/server.sfe.test.ts apps/cli/test/single.sfe.test.ts",
    "test:ums": "UMS_IMPL_MODULE=./apps/api/src/ums/engine.ts UMS_IMPL_EXPORT=createUmsEngine bun test tests/unit/*.test.ts tests/integration/*.test.ts",
    "test": "bun run test:api && bun run test:ums",
    "eval:golden-replay": "bun scripts/eval-golden-replay.ts --json",
    "eval:adapter-conformance": "bun scripts/eval-adapter-conformance.ts --json",
    "eval:grounded-recall": "bun scripts/eval-grounded-recall.ts --json",
    "eval:lean": "bun run eval:golden-replay && bun run eval:adapter-conformance && bun run eval:grounded-recall",
    "lint:ts": "oxlint --deny-warnings --tsconfig tsconfig.json --ignore-pattern \"apps/**/test/**/*.ts\" --ignore-pattern \"apps/**/bench/**/*.ts\" --ignore-pattern \"**/adapter-registry.test.ts\" apps libs scripts",
    "lint:config-json": "bun scripts/validate-strict-json.ts tsconfig*.json apps/*/tsconfig.json libs/shared/tsconfig.json",
    "validate:tsconfig-policy": "bun scripts/validate-tsconfig-policy-lock.ts",
    "validate:effect-beta-pin": "bun scripts/validate-effect-beta-pin.ts",
    "validate:runtime-ts-suppressions": "bun scripts/validate-runtime-ts-suppressions.ts",
    "validate:no-legacy-js-sources": "bun scripts/validate-no-legacy-js-sources.ts",
    "validate:provenance-health": "bun scripts/validate-provenance-health.ts",
    "validate:legacy-shims": "bun scripts/validate-legacy-runtime-shims.ts",
    "validate:cutover": "bun scripts/validate-legacy-runtime-cutover.ts",
    "validate:vector-eval": "bun scripts/validate-vector-retrieval-evaluation.ts",
    "validate:federation-model": "bun scripts/validate-cross-repo-federation-model.ts",
    "validate:schema-boundaries": "bun scripts/validate-schema-boundaries.ts",
    "format:check:ts": "oxfmt --check \"{apps,libs,scripts,tests,benchmarks}/**/*.ts\" \"tsconfig*.json\" \"apps/*/tsconfig.json\" \"apps/*/{test,bench}/tsconfig.json\" \"libs/shared/tsconfig.json\" \"scripts/tsconfig.json\" \"tests/tsconfig.json\" \"benchmarks/tsconfig.json\"",
    "format:write:ts": "oxfmt \"{apps,libs,scripts,tests,benchmarks}/**/*.ts\" \"tsconfig*.json\" \"apps/*/tsconfig.json\" \"apps/*/{test,bench}/tsconfig.json\" \"libs/shared/tsconfig.json\" \"scripts/tsconfig.json\" \"tests/tsconfig.json\" \"benchmarks/tsconfig.json\"",
    "ultracite:check": "ultracite check",
    "ultracite:fix": "ultracite fix",
    "quality:ts": "bun run lint:ts && bun run lint:config-json && bun run validate:tsconfig-policy && bun run validate:effect-beta-pin && bun run validate:runtime-ts-suppressions && bun run validate:no-legacy-js-sources && bun run validate:legacy-shims && bun run validate:cutover && bun run validate:vector-eval && bun run validate:federation-model && bun run validate:schema-boundaries && bun run validate:ingestion && bun run format:check:ts && bun run typecheck",
    "ci:verify": "bun run quality:ts && bun run test && bun run eval:lean && bun run test:sfe && bun run build:sfe:single",
    "typecheck": "bun x tsc -b --pretty false",
    "bench:api": "bun apps/api/bench/benchmark.ts",
    "bench:ums": "UMS_IMPL_MODULE=./apps/api/src/ums/engine.ts UMS_IMPL_EXPORT=createUmsEngine bun benchmarks/ums-latency-benchmark.ts",
    "bench": "bun run bench:api && bun run bench:ums",
    "validate:ingestion": "bun scripts/validate-ingestion.ts --mode check",
    "validate:ingestion:refresh": "bun scripts/validate-ingestion.ts --mode refresh --output docs/reports/multi-store-ingestion-validation-summary.json",
    "validate:ingestion:local": "bun scripts/validate-ingestion.ts --mode local",
    "backfill:provenance": "bun scripts/backfill-provenance-schema.ts",
    "ingest:coding-history": "bun scripts/ingest-coding-history.ts",
    "pilot:report": "bun scripts/generate-pilot-rollout-report.ts",
    "pilot:dashboard": "bun scripts/generate-pilot-kpi-dashboard.ts",
    "pilot:tune": "bun scripts/generate-ranking-decay-tuning.ts",
    "pilot:slo": "bun scripts/evaluate-production-slos.ts",
    "benchmark:ncm-hybrid": "bun scripts/benchmark-cass-vs-ncm-hybrid.ts --compact"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.2.0",
    "effect": "4.0.0-beta.27"
  },
  "devDependencies": {
    "@effect-native/bun-test": "4.0.0",
    "@types/bun": "1.3.10",
    "@types/node": "24.12.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "5.8.2",
    "ultracite": "^7.2.4"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "packageManager": "bun@1.3.10"
}
